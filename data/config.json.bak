{
  "version": "1.0",
  "ai": {
    "provider": "openai",
    "model": "deepseek-chat",
    "base_url": null,
    "api_key_env": "OPENAI_API_KEY",
    "temperature": 0.3,
    "max_tokens": 8192,
    "throttle_sec": 0.0,
    "analysis_concurrency": 1,
    "enrichment_concurrency": 1,
    "languages": [
      "zh"
    ],
    "azure_endpoint_env": null,
    "api_version": null
  },
  "sources": {
    "github": [
      {
        "type": "repo_releases",
        "username": null,
        "owner": "sgl-project",
        "repo": "sglang",
        "enabled": false
      },
      {
        "type": "repo_releases",
        "username": null,
        "owner": "vllm-project",
        "repo": "vllm",
        "enabled": false
      },
      {
        "type": "user_events",
        "username": "karpathy",
        "owner": null,
        "repo": null,
        "enabled": false
      },
      {
        "type": "repo_releases",
        "username": null,
        "owner": "triton-lang",
        "repo": "triton",
        "enabled": false
      }
    ],
    "hackernews": {
      "enabled": true,
      "fetch_top_stories": 30,
      "min_score": 100
    },
